        <rdfs:label xml:lang="en">EMERGENCY HALT (ETCS Stop)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/def/RailwayFloodTwin#Fosse_terre_revetu_0 -->


