}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "TRAN Trong-Tin"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "Ontology representing the domain of railway infrastructure flood-risk assessment within a digital twin context. Covers infrastructure assets (track segments, culverts, bridges, ditches, embankments), hydrological simulation (rainfall, soil water index, runoff), hydraulic modeling (water surface elevation, flood polygons), vulnerability assessment (fragility curves, failure probability), and RAMS-compliant operational alerting (GREEN/YELLOW/RED)."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "http://purl.org/NET/rdflicense/cc-by4.0"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "Railway Flood-Risk Digital Twin Ontology"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "rft"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "https://w3id.org/def/RailwayFloodTwin#"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#decimal",
    "@value" : "1.0"
  } ]
}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#AlertStatus",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A RAMS-compliant traffic-light risk category: GREEN (LOW, P<20%), YELLOW (MEDIUM, P 20-50%), or RED (HIGH, P>50%)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "alert status"
  } ]
}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#AlertVerdict",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An operational risk verdict linking an asset, WSE, failure probability, alert status and directive. Implements the W3C n-ary relation pattern."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "alert verdict"
  } ]
