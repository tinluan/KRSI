  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An instruction issued to train dispatchers based on alert status"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "operational directive"
  } ]
}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#RED",
