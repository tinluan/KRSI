    "@language" : "en",
    "@value" : "lined ditch"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://www.wikidata.org/entity/Q173036"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/def/RailwayFloodTwin#DrainageAsset"
  } ]
}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#Observation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An act of measuring a property, producing a result value at a timestamp"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "observation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://www.wikidata.org/entity/Q24953776"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/sosa/Observation"
  } ]
}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#OperationalDirective",
