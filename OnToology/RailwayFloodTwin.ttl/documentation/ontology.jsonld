  } ]
}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#EmergencyHalt",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/def/RailwayFloodTwin#OperationalDirective"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Halt all trains — water on track surface, ballast failure imminent"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "EMERGENCY HALT (ETCS Stop)"
  } ]
}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#FailureProbability",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A computed probability (0.0-1.0) of ballast or structural failure due to flood water depth"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "failure probability"
  } ]
}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#FloodPolygon",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A geographic polygon representing the spatial extent of inundation at a simulation timestep"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "flood polygon"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://www.wikidata.org/entity/Q8068"
  } ]
}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#FragilityCurve",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A log-normal probability distribution mapping water depth to probability of structural failure. P_failure = Phi(ln(depth / median_depth) / sigma)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "fragility curve"
  } ]
}, {
  "@id" : "https://w3id.org/def/RailwayFloodTwin#GREEN",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/def/RailwayFloodTwin#AlertStatus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "LOW risk — P_failure below 20%"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GREEN"
  } ],
  "https://w3id.org/def/RailwayFloodTwin#triggers" : [ {
    "@id" : "https://w3id.org/def/RailwayFloodTwin#Standby"
  } ]
}, {
